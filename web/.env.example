# 依規格 5.網站技術架構圖：正式環境 MySQL (Linode Managed DB)，開發環境 MySQL (XAMPP 本機)
# 複製此檔為 .env 並填入實際連線字串

# 開發：XAMPP MySQL 預設 (帳號 root、密碼空白、port 3306)
# DATABASE_URL="mysql://root:@localhost:3306/shenhua_korean"

# 開發：若有設定 root 密碼
# DATABASE_URL="mysql://root:你的密碼@localhost:3306/shenhua_korean"

# 正式：Linode Managed MySQL（請向主機商取得連線資訊）
# DATABASE_URL="mysql://使用者:密碼@主機:3306/資料庫名?sslaccept=strict"

# 後台登入用 JWT 密鑰（產生 token 時使用，請替換為隨機字串）
# JWT_SECRET=your-secret-key-change-in-production
